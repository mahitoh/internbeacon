generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  role          Role           @default(STUDENT)
  name          String
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company?
  messages      Message[]
  notifications Notification[]
  student       Student?
}

model Student {
  id              String        @id @default(cuid())
  userId          String        @unique
  bio             String?
  skills          String[]
  profileStrength Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  applications    Application[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id          String   @id @default(cuid())
  userId      String   @unique
  description String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers      Offer[]
}

model Offer {
  id           String        @id @default(cuid())
  companyId    String
  title        String
  description  String
  salary       String?
  location     String?
  category     String?
  languages    String[]
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Application {
  id           String            @id @default(cuid())
  studentId    String
  offerId      String
  status       ApplicationStatus @default(PENDING)
  coverLetter  String?
  resume       String?
  portfolio    String?
  availability String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  offer        Offer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, offerId])
}

model Match {
  id        String   @id @default(cuid())
  studentId String
  offerId   String
  score     Float
  createdAt DateTime @default(now())
}

model ChatRoom {
  id           String    @id @default(cuid())
  participants String[]
  createdAt    DateTime  @default(now())
  messages     Message[]
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  roomId    String
  content   String
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  message   String
  type      NotificationType @default(IN_APP)
  sent      Boolean          @default(false)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  STUDENT
  COMPANY
  ADMIN
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum NotificationType {
  IN_APP
  EMAIL
  SMS
}
