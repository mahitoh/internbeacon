generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  role          Role           @default(STUDENT)
  name          String
  refreshToken  String?
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company       Company?
  student       Student?
  notifications Notification[]
  messages      Message[]
}

model School {
  id        String    @id @default(cuid())
  name      String    @unique
  city      String?
  website   String?
  type      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  students  Student[]

  @@index([city])
}

model Student {
  id              String        @id @default(cuid())
  userId          String        @unique
  schoolId        String?
  bio             String?
  skills          String[]      @default([])
  profileStrength Int           @default(0)
  avatarUrl       String?
  city            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  applications    Application[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId])
}

model Company {
  id            String    @id @default(cuid())
  userId        String    @unique
  description   String?
  website       String?
  industry      String?
  city          String?
  logoUrl       String?
  coverImageUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers        Offer[]

  @@index([industry])
  @@index([city])
}

model Offer {
  id           String        @id @default(cuid())
  companyId    String
  title        String
  description  String
  salary       String?
  location     String?
  category     String?
  languages    String[]      @default([])
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications Application[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([location])
  @@index([category])
}

model Application {
  id           String            @id @default(cuid())
  studentId    String
  offerId      String
  status       ApplicationStatus @default(PENDING)
  coverLetter  String?
  resume       String?
  portfolio    String?
  availability String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  offer        Offer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, offerId])
  @@index([studentId])
  @@index([offerId])
}

model Match {
  id        String   @id @default(cuid())
  studentId String
  offerId   String
  score     Float
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([offerId])
}

model ChatRoom {
  id           String    @id @default(cuid())
  participants String[]
  createdAt    DateTime  @default(now())

  messages     Message[]
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  roomId    String
  content   String
  createdAt DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([roomId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  message   String
  type      NotificationType @default(IN_APP)
  sent      Boolean          @default(false)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum Role {
  STUDENT
  COMPANY
  ADMIN
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum NotificationType {
  IN_APP
  EMAIL
  SMS
}
