# Database
DATABASE_URL="postgresql://..."

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# AI Configuration (choose one provider)
AI_PROVIDER=openai  # Options: openai, groq, gemini, huggingface

# OpenAI (Recommended - $5 free credit for new users)
OPENAI_API_KEY=your_o...here

# Groq (Fast inference, OpenAI-compatible API)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (Free tier available)
GEMINI_API_KEY=your_g...here

# Hugging Face (Free inference)
HUGGINGFACE_API_KEY=your_h...here