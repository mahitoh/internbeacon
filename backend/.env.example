# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → API

SUPABASE_URL=https://bmlttdbgdvssklbouuoj.supabase.co

# Anon/public key — safe to expose to browser (used for signIn / refresh)
SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — KEEP SECRET, server-side only (used for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT secret — used to verify Supabase-issued JWTs on the backend
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ─── Database (Supabase PostgreSQL via Prisma) ─────────────────────────────────
# Get password from: Supabase Dashboard → Settings → Database → Connection string
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543, pgbouncer=true)
# Use the "Session" pooler or direct URL for DIRECT_URL (port 5432, for migrations)

DATABASE_URL="postgresql://postgres.bmlttdbgdvssklbouuoj:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.bmlttdbgdvssklbouuoj:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_CV_SIZE_MB=5
MAX_LOGO_SIZE_MB=2

# ─── Email (optional — Supabase sends auth emails automatically) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="InternBeacon <no-reply@internbeacon.cm>"
